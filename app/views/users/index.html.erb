<% content_for :title, "Find People" %>

<div class="max-w-2xl mx-auto">
  <h1 class="text-2xl font-bold mb-6">Find People</h1>

  <%# Search by name/username %>
  <%= form_with url: users_path, method: :get do |f| %>
    <div class="relative mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
           class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-500 pointer-events-none">
        <circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
      <%= f.text_field :q, value: params[:q],
            placeholder: "Search by name, username or email…",
            autofocus: params[:q].blank?,
            class: "w-full bg-zinc-800 border border-zinc-600 rounded-xl pl-9 pr-4 py-2.5 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-lime-400 transition-colors" %>
    </div>
  <% end %>

  <%# Contact Picker — shown only on supporting browsers via JS %>
  <div data-controller="contacts"
       data-search-url="<%= contacts_search_users_path %>"
       class="mb-6">
    <button type="button"
            data-contacts-target="button"
            data-action="click->contacts#pick"
            class="flex items-center gap-2 w-full justify-center border border-zinc-600 hover:border-lime-400 hover:text-lime-400 text-gray-400 font-bold px-4 py-3 rounded-xl text-sm transition-colors cursor-pointer">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/>
        <path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>
      </svg>
      Find from Contacts
    </button>
    <p data-contacts-target="status" class="text-xs text-gray-500 text-center mt-2"></p>
  </div>

  <%# Contact search results land here via Turbo Stream %>
  <div id="contacts_results" class="mb-4"></div>

  <%# Name/username search results %>
  <% if params[:q].present? && @users.empty? %>
    <p class="text-gray-500 text-sm text-center py-8">No users found for "<%= params[:q] %>".</p>
  <% elsif @users.any? %>
    <div class="space-y-2">
      <% @users.each do |user| %>
        <div class="flex items-center justify-between border border-zinc-600 rounded-xl px-4 py-3 hover:border-gray-600 transition-colors">
          <div>
            <%= link_to user_path(user), class: "font-semibold text-white hover:text-lime-400 transition-colors" do %>
              <%= user.display %>
            <% end %>
            <% if user.username.present? %>
              <p class="text-gray-600 text-xs">@<%= user.username %></p>
            <% end %>
          </div>
          <% follow_state = Current.user.follow_state_for(user) %>
          <% follow = Current.user.follows_as_follower.find_by(following: user) %>
          <%= render "shared/follow_button", user: user, follow_state: follow_state, follow: follow %>
        </div>
      <% end %>
    </div>
  <% elsif params[:q].blank? %>
    <p class="text-gray-600 text-sm text-center py-8">Type a name or username to search.</p>
  <% end %>
</div>
