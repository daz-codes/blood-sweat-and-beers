<% content_for :title, "Build a Training Program" %>

<div class="max-w-2xl mx-auto px-4 pb-12" data-controller="program-form">
  <div class="flex items-center justify-between mb-8">
    <div>
      <p class="text-lime-400 text-xs font-black uppercase tracking-widest mb-1">Programs</p>
      <h1 class="text-3xl font-black tracking-tight uppercase" style="font-family: 'Jost', sans-serif">Build a Program</h1>
      <p class="text-gray-500 text-sm mt-1">Generate a multi-week training block tailored to you.</p>
    </div>
    <%= link_to library_path, class: "flex-shrink-0 flex items-center justify-center w-9 h-9 rounded-full text-gray-500 hover:text-white hover:bg-zinc-700 transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    <% end %>
  </div>

  <%= form_with model: @program, url: programs_path, local: true do |f| %>

    <%# Session Type %>
    <div class="mb-8">
      <p class="text-sm font-bold text-gray-300 uppercase tracking-wide mb-1">Session Type</p>
      <p class="text-xs text-gray-500 mb-4">The style of training this program is built around.</p>
      <div class="flex flex-wrap gap-2">
        <% @main_tags.each do |tag| %>
          <label class="cursor-pointer">
            <%= f.radio_button :tag_id, tag.id, class: "peer sr-only",
                checked: @program.tag_id == tag.id %>
            <span class="inline-block border-2 border-zinc-600 rounded-full px-4 py-1.5 text-sm font-medium text-gray-400 peer-checked:border-lime-400 peer-checked:bg-lime-400 peer-checked:text-zinc-900 peer-checked:font-bold transition-all select-none">
              <%= tag.name %>
            </span>
          </label>
        <% end %>
      </div>
      <div class="mt-3 flex items-center gap-3">
        <span class="text-xs text-gray-600 flex-shrink-0">or type your own:</span>
        <%= text_field_tag :custom_activity, params[:custom_activity],
            placeholder: "e.g. Powerlifting, Olympic Lifting, Yoga…",
            class: "flex-1 bg-zinc-800 border border-zinc-700 rounded-xl px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-lime-400 transition-colors" %>
      </div>
      <% if @program.errors[:tag_id].any? %>
        <p class="text-red-400 text-xs mt-2"><%= @program.errors[:tag_id].first %></p>
      <% end %>
    </div>

    <%# Program Length — slider 2–16 weeks %>
    <div class="mb-8">
      <div class="flex items-baseline justify-between mb-3">
        <p class="text-sm font-bold text-gray-300 uppercase tracking-wide">Program Length</p>
        <p class="text-3xl font-black text-white">
          <span data-program-form-target="weeksDisplay"><%= @program.weeks_count %></span>
          <span class="text-base font-normal text-gray-400">weeks</span>
        </p>
      </div>
      <%= f.range_field :weeks_count, value: @program.weeks_count, min: 2, max: 16, step: 1,
          class: "w-full h-2 bg-zinc-700 rounded-lg appearance-none cursor-pointer accent-lime-400",
          data: { program_form_target: "weeksInput", action: "input->program-form#updateWeeks" },
          required: true %>
      <div class="flex justify-between text-xs text-gray-600 mt-1.5">
        <span>2 weeks</span><span>16 weeks</span>
      </div>
    </div>

    <%# Sessions per week %>
    <div class="mb-8">
      <p class="text-sm font-bold text-gray-300 uppercase tracking-wide mb-4">Sessions per Week</p>
      <div class="flex gap-2 flex-wrap">
        <% (2..5).each do |n| %>
          <label class="cursor-pointer">
            <%= f.radio_button :sessions_per_week, n, class: "peer sr-only",
                checked: @program.sessions_per_week == n,
                data: { action: "change->program-form#updateSessions" } %>
            <div class="border-2 border-zinc-600 rounded-xl px-5 py-3 peer-checked:border-lime-400 peer-checked:bg-lime-400/15 transition-all text-center min-w-[72px]">
              <p class="font-black text-base"><%= n %>×</p>
              <p class="text-gray-500 text-xs">per week</p>
            </div>
          </label>
        <% end %>
      </div>
    </div>

    <%# Duration — reuse duration-slider Stimulus controller %>
    <div class="mb-8" data-controller="duration-slider">
      <div class="flex items-baseline justify-between mb-3">
        <p class="text-sm font-bold text-gray-300 uppercase tracking-wide">Session Duration</p>
        <p class="text-3xl font-black text-white">
          <span data-duration-slider-target="display"><%= @program.duration_mins %></span>
          <span class="text-base font-normal text-gray-400">min</span>
        </p>
      </div>
      <%= f.range_field :duration_mins, value: @program.duration_mins, min: 20, max: 120, step: 5,
          class: "w-full h-2 bg-zinc-700 rounded-lg appearance-none cursor-pointer accent-lime-400",
          data: { duration_slider_target: "input", action: "input->duration-slider#update" },
          required: true %>
      <div class="flex justify-between text-xs text-gray-600 mt-1.5">
        <span>20 min</span><span>2 hrs</span>
      </div>
    </div>

    <%# Difficulty %>
    <div class="mb-8">
      <p class="text-sm font-bold text-gray-300 uppercase tracking-wide mb-4">Difficulty</p>
      <div class="grid grid-cols-3 gap-3">
        <% [["beginner", "Beginner", "Building base"], ["intermediate", "Intermediate", "Regular training"], ["advanced", "Advanced", "Competition prep"]].each do |value, label, desc| %>
          <label class="cursor-pointer">
            <%= f.radio_button :difficulty, value, class: "peer sr-only", checked: @program.difficulty == value %>
            <div class="border-2 border-zinc-600 rounded-xl p-3 peer-checked:border-lime-400 peer-checked:bg-lime-400/10 transition-all text-center">
              <p class="font-black text-sm"><%= label %></p>
              <p class="text-gray-500 text-xs mt-0.5"><%= desc %></p>
            </div>
          </label>
        <% end %>
      </div>
    </div>

    <%# Session focus — dynamically matches sessions_per_week %>
    <div class="mb-10">
      <p class="text-sm font-bold text-gray-300 uppercase tracking-wide mb-1">Session Focus <span class="text-gray-600 normal-case font-normal">(optional)</span></p>
      <p class="text-xs text-gray-500 mb-4">Give each weekly session a focus — e.g. "strength", "cardio", "upper body". Leave blank and the AI will auto-balance.</p>
      <div class="space-y-2">
        <% (1..5).each do |i| %>
          <div class="flex items-center gap-3 <%= i > @program.sessions_per_week ? 'hidden' : '' %>"
               data-program-form-target="sessionRow">
            <span class="text-gray-600 text-xs font-black uppercase tracking-widest w-16 flex-shrink-0">Day <%= i %></span>
            <%= text_field_tag "session_notes[]", nil,
                placeholder: "e.g. strength, cardio, upper body…",
                class: "flex-1 bg-zinc-800 border border-zinc-600 rounded-xl px-4 py-2.5 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-lime-400 transition-colors" %>
          </div>
        <% end %>
      </div>
    </div>

    <% if @program.errors.any? %>
      <div class="bg-red-900/30 border border-red-700 rounded-xl px-4 py-3 mb-6">
        <ul class="text-red-400 text-sm space-y-1">
          <% @program.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= f.submit "Build Program",
        class: "w-full bg-volt hover:bg-volt/80 active:opacity-90 text-zinc-950 font-black py-4 rounded-xl text-base transition-colors cursor-pointer uppercase tracking-wide shadow-sm shadow-volt/20",
        data: { turbo_submits_with: "Generating program…" } %>

  <% end %>
</div>
