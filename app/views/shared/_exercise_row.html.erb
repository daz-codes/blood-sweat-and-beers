<%# Locals: exercise (Hash), section (Hash), workout (Workout, optional),
#           section_index (Integer, optional), exercise_index (Integer, optional),
#           swappable (Boolean, optional), is_tabata (Boolean, optional) %>
<% is_tabata    = local_assigns.fetch(:is_tabata, section["format"] == "tabata") %>
<% swappable    = local_assigns.fetch(:swappable, false) %>
<% dom_id       = workout && swappable ? "exercise_#{workout.id}_#{section_index}_#{exercise_index}" : nil %>

<div <% if dom_id %>id="<%= dom_id %>"<% end %> class="px-3 py-2.5 border-t border-zinc-700/50"
     <% if swappable && workout %>data-controller="swap-exercise"<% end %>>
  <div class="flex items-start justify-between gap-2">
    <div>
      <p class="text-white text-sm font-semibold" <% if swappable && workout %>data-swap-exercise-target="name"<% end %>><%= exercise["name"] %></p>
      <% if is_tabata %>
        <p class="text-gray-400 text-xs italic mt-0.5">20s hard effort / 10s easy</p>
      <% end %>
    </div>
    <% if swappable && workout %>
      <%= button_to swap_exercise_workout_path(workout),
            params: { section_index: section_index, exercise_index: exercise_index },
            method: :post,
            form: { class: "flex-shrink-0", data: { action: "submit->swap-exercise#swap" } },
            class: "text-gray-600 hover:text-lime-400 transition-colors cursor-pointer p-0.5 rounded",
            title: "Swap for an alternative" do %>
        <svg data-swap-exercise-target="icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"
             stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="1 4 1 10 7 10"/>
          <polyline points="23 20 23 14 17 14"/>
          <path d="M20.49 9A9 9 0 0 0 5.64 5.64L1 10m22 4l-4.64 4.36A9 9 0 0 1 3.51 15"/>
        </svg>
      <% end %>
    <% end %>
  </div>

  <% has_metric = exercise["distance_m"] || exercise["duration_s"] || exercise["weight_kg"] ||
                  (!is_tabata && (exercise["calories"] || exercise["reps"])) %>
  <% if has_metric || exercise["notes"].present? %>
    <div class="flex items-center gap-1.5 mt-1 flex-wrap" <% if swappable && workout %>data-swap-exercise-target="details"<% end %>>
      <% if exercise["distance_m"] %>
        <span class="text-xs font-bold text-sky-200"><%= exercise["distance_m"] %>m</span>
      <% elsif !is_tabata && exercise["calories"] %>
        <span class="text-xs font-bold text-sky-200"><%= exercise["calories"] %> cal</span>
      <% elsif !is_tabata && exercise["reps"] %>
        <span class="text-xs font-bold text-sky-200"><%= exercise["reps"] %> reps</span>
      <% elsif exercise["duration_s"] %>
        <% ds = exercise["duration_s"].to_i; dm = ds / 60; dr = ds % 60 %>
        <span class="text-xs font-bold text-sky-200"><%= dm > 0 ? "#{dm}min #{dr > 0 ? "#{dr}s" : ""}".strip : "#{ds}s" %></span>
      <% end %>
      <% if exercise["weight_kg"].to_f > 0 %>
        <span class="text-xs font-bold text-sky-200"><%= exercise["weight_kg"] %>kg</span>
      <% end %>
      <% if !is_tabata && exercise["notes"].present? %>
        <span class="text-gray-400 text-xs italic"><%= exercise["notes"] %></span>
      <% end %>
    </div>
  <% end %>
</div>
