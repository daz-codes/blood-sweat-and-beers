<%# Locals: section (Hash), distance_sport (Boolean, optional) %>
<% sec_format = section["format"].to_s %>
<% sec_mins = sec_format == "tabata" ? 4 : (section["duration_mins"].to_i > 0 ? section["duration_mins"].to_i : nil) %>

<%# Section distance (for distance-based sports) %>
<% if local_assigns[:distance_sport]
     _dist_m = section_distance_m(section)
     if _dist_m >= 1000
       sec_dist_val  = (_dist_m / 1000.0).round(1).to_s.delete_suffix(".0")
       sec_dist_unit = "km"
     elsif _dist_m > 0
       sec_dist_val  = _dist_m.to_s
       sec_dist_unit = "m"
     end
   end %>

<%# Build sequence string for ladder/mountain sections %>
<% ladder_seq_str = nil
   if %w[ladder mountain].include?(sec_format)
     step = [section["step"].to_f, 1.0].max
     varies_lbl = { "reps" => "reps", "calories" => "cal", "kg" => "kg", "distance_m" => "m" }.fetch(section["varies"].to_s, section["varies"].to_s)
     if sec_format == "ladder"
       sv = section["start"].to_f; ev = section["end"].to_f
       vals = []
       if sv <= ev
         v = sv; while v <= ev + 0.001; vals << v; v += step; end
       else
         v = sv; while v >= ev - 0.001; vals << v; v -= step; end
       end
     else
       sv = section["start"].to_f; pk = section["peak"].to_f; ev = section["end"].to_f
       up = []; v = sv; while v <= pk + 0.001; up << v; v += step; end
       dn = []; v = pk - step; while v >= ev - 0.001; dn << v; v -= step; end
       vals = up + dn
     end
     vals = vals.map { |v| v == v.to_i ? v.to_i : v }
     seq = vals.size <= 10 ? vals.join(" · ") : "#{vals.first(3).join(" · ")} · … · #{vals.last}"
     ladder_seq_str = "#{seq} #{varies_lbl}".strip
   end %>

<% format_desc = case sec_format
   when "rounds"
     parts = []
     parts << "#{section["rounds"]} rounds" if section["rounds"].to_i > 0
     parts << "#{section["rest_secs"]}s rest after each round" if section["rest_secs"].to_i > 0
     parts.join(" · ").presence
   when "amrap"
     section["duration_mins"] ? "AMRAP · #{section["duration_mins"]} min" : "AMRAP"
   when "emom"
     section["duration_mins"] ? "Every Minute On the Minute · #{section["duration_mins"]} min" : "Every Minute On the Minute"
   when "tabata"
     "Tabata · 8 rounds · 20s work · 10s rest"
   when "for_time"
     "For Time"
   when "ladder", "mountain"
     parts = [ ladder_seq_str ]
     parts << "#{section["rest_between_rungs"]}s rest between rungs" if section["rest_between_rungs"].to_i > 0
     parts.compact.join(" · ").presence
   end %>

<div class="bg-zinc-900/60 rounded-xl overflow-hidden border border-zinc-600/50">

  <%# Header: section name + time circle; format description below name %>
  <div class="px-3 py-2.5 bg-zinc-700/40">
    <div class="flex items-center justify-between gap-2">
      <span class="font-black text-white text-xs uppercase tracking-widest" style="font-family: 'Jost', sans-serif"><%= section["name"] %></span>
      <% if local_assigns[:distance_sport] && defined?(sec_dist_val) && sec_dist_val %>
        <div class="flex flex-col items-center justify-center w-8 h-8 rounded-full bg-sky-500 shadow-sm shadow-sky-500/30 flex-shrink-0">
          <span class="text-white font-black text-[9px] leading-none"><%= sec_dist_val %></span>
          <span class="text-sky-200 text-[7px] leading-none mt-0.5"><%= sec_dist_unit %></span>
        </div>
      <% elsif sec_mins %>
        <div class="flex flex-col items-center justify-center w-8 h-8 rounded-full bg-volt flex-shrink-0">
          <span class="text-zinc-900 font-black text-xs leading-none"><%= sec_mins %></span>
          <span class="text-zinc-700 text-[7px] leading-none mt-0.5">min</span>
        </div>
      <% end %>
    </div>
    <% if format_desc.present? %>
      <p class="text-gray-400 text-xs mt-1 leading-relaxed"><%= format_desc %></p>
    <% end %>
  </div>

  <%# Exercises — name on top, metrics + notes inline below %>
  <% Array(section["exercises"]).each do |exercise| %>
    <div class="px-3 py-2.5 border-t border-zinc-700/50">
      <p class="text-white text-sm font-semibold"><%= exercise["name"] %></p>
      <% is_tabata = sec_format == "tabata" %>
      <% has_metric = exercise["distance_m"] || exercise["duration_s"] || exercise["weight_kg"] ||
                      (!is_tabata && (exercise["calories"] || exercise["reps"])) %>
      <% if has_metric || exercise["notes"].present? %>
        <div class="flex items-center gap-1.5 mt-1 flex-wrap">
          <% if exercise["distance_m"] %>
            <span class="text-xs font-bold text-lime-400"><%= exercise["distance_m"] %>m</span>
          <% elsif !is_tabata && exercise["calories"] %>
            <span class="text-xs font-bold text-lime-400"><%= exercise["calories"] %> cal</span>
          <% elsif !is_tabata && exercise["reps"] %>
            <span class="text-xs font-bold text-lime-400"><%= exercise["reps"] %> reps</span>
          <% elsif exercise["duration_s"] %>
            <% ds = exercise["duration_s"].to_i; dm = ds / 60; dr = ds % 60 %>
            <span class="text-xs font-bold text-lime-400"><%= dm > 0 ? "#{dm}m #{dr > 0 ? "#{dr}s" : ""}".strip : "#{ds}s" %></span>
          <% end %>
          <% if exercise["weight_kg"].to_f > 0 %>
            <span class="text-xs font-bold text-lime-400"><%= exercise["weight_kg"] %>kg</span>
          <% end %>
          <% if exercise["notes"].present? %>
            <span class="text-gray-400 text-xs italic"><%= exercise["notes"] %></span>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>

  <%# Footer: section notes only %>
  <% if section["notes"].present? %>
    <div class="px-3 py-2 border-t border-zinc-600/40 bg-zinc-700/20">
      <p class="text-gray-400 text-xs leading-relaxed"><%= section["notes"] %></p>
    </div>
  <% end %>

</div>
