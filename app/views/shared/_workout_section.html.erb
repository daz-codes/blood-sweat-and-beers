<%# Locals: section (Hash), distance_sport (Boolean, optional),
#           workout (Workout, optional), section_index (Integer, optional),
#           swappable (Boolean, optional) %>
<% swappable     = local_assigns.fetch(:swappable, false)
   workout       = local_assigns.fetch(:workout, nil)
   section_index = local_assigns.fetch(:section_index, nil) %>
<% sec_format = section["format"].to_s %>
<% sec_mins = sec_format == "tabata" ? 4 : (section["duration_mins"].to_i > 0 ? section["duration_mins"].to_i : nil) %>

<%# Section distance (for distance-based sports) %>
<% if local_assigns[:distance_sport]
     _dist_m = section_distance_m(section)
     if _dist_m >= 1000
       sec_dist_val  = (_dist_m / 1000.0).round(1).to_s.delete_suffix(".0")
       sec_dist_unit = "km"
     elsif _dist_m > 0
       sec_dist_val  = _dist_m.to_s
       sec_dist_unit = "m"
     end
   end %>

<%# Build sequence string for ladder/mountain sections %>
<% ladder_seq_str = nil
   if %w[ladder mountain].include?(sec_format)
     step = [section["step"].to_f, 1.0].max
     varies_lbl = { "reps" => "reps", "calories" => "cal", "kg" => "kg", "distance_m" => "m" }.fetch(section["varies"].to_s, section["varies"].to_s)
     if sec_format == "ladder"
       sv = section["start"].to_f; ev = section["end"].to_f
       vals = []
       if sv <= ev
         v = sv; while v <= ev + 0.001; vals << v; v += step; end
       else
         v = sv; while v >= ev - 0.001; vals << v; v -= step; end
       end
     else
       sv = section["start"].to_f; pk = section["peak"].to_f; ev = section["end"].to_f
       up = []; v = sv; while v <= pk + 0.001; up << v; v += step; end
       dn = []; v = pk - step; while v >= ev - 0.001; dn << v; v -= step; end
       vals = up + dn
     end
     vals = vals.map { |v| v == v.to_i ? v.to_i : v }
     seq = vals.size <= 10 ? vals.join(" · ") : "#{vals.first(3).join(" · ")} · … · #{vals.last}"
     ladder_seq_str = "#{seq} #{varies_lbl}".strip
   end %>

<%# fmt_label = bold green modality name, fmt_detail = gray italic description, fmt_interval = bold green suffix (tabata only) %>
<% fmt_label, fmt_detail, fmt_interval = case sec_format
   when "rounds"
     label  = section["rounds"].to_i > 0 ? "#{section["rounds"]} rounds" : nil
     detail = section["rest_secs"].to_i > 0 ? "#{section["rest_secs"]}s rest after each round" : nil
     [label, detail]
   when "amrap"
     ["AMRAP", section["duration_mins"] ? "#{section["duration_mins"]} min" : nil]
   when "emom"
     detail_parts = []
     detail_parts << "#{section["duration_mins"]} min" if section["duration_mins"]
     if section["emom_style"] == "rotating"
       n = Array(section["exercises"]).size
       rounds_each = n > 0 && section["duration_mins"].to_i > 0 ? section["duration_mins"].to_i / n : nil
       detail_parts << (rounds_each ? "#{n} exercises · #{rounds_each} rounds each" : "#{n} exercises rotating")
     end
     ["EMOM", detail_parts.join(" · ").presence]
   when "tabata"
     n = Array(section["exercises"]).size
     rotation = case n
       when 2 then "alternating · 4 rounds each"
       when 4 then "rotating · 2 rounds each"
       when 8 then "1 round each"
       else "8 rounds"
       end
     ["Tabata", rotation]
   when "for_time"
     ["For Time", nil]
   when "hundred"
     ["100 Reps", "For Time"]
   when "ladder", "mountain"
     parts = [ ladder_seq_str ]
     parts << "#{section["rest_between_rungs"]}s rest between rungs" if section["rest_between_rungs"].to_i > 0
     [sec_format.capitalize, parts.compact.join(" · ").presence]
   when "matrix"
     rest = section["rest_secs"].to_i > 0 ? "#{section["rest_secs"]}s rest between rounds" : nil
     ["Matrix", rest]
   else
     [nil, nil]
   end %>

<div class="bg-zinc-900/60 rounded-xl overflow-hidden border border-zinc-600/50">

  <%# Header: section name + time circle; format description below name %>
  <div class="px-3 py-2.5 bg-zinc-700/40">
    <div class="flex items-center justify-between gap-2">
      <span class="font-black text-white text-xs uppercase tracking-widest" style="font-family: 'Jost', sans-serif"><%= section["name"] %></span>
      <% if local_assigns[:distance_sport] && defined?(sec_dist_val) && sec_dist_val %>
        <div class="flex flex-col items-center justify-center w-8 h-8 rounded-full bg-sky-500 shadow-sm shadow-sky-500/30 flex-shrink-0">
          <span class="text-white font-black text-[9px] leading-none"><%= sec_dist_val %></span>
          <span class="text-sky-200 text-[7px] leading-none mt-0.5"><%= sec_dist_unit %></span>
        </div>
      <% end %>
    </div>
    <% if fmt_label.present? %>
      <p class="text-xs mt-1 leading-relaxed">
        <span class="text-lime-400 font-bold"><%= fmt_label %></span>
        <% if fmt_detail.present? %><span class="text-gray-400 italic"> · <%= fmt_detail %></span><% end %>
        <% if fmt_interval.present? %><span class="text-gray-400 italic"> · <%= fmt_interval %></span><% end %>
      </p>
    <% end %>
  </div>

  <%# Exercises %>
  <% if sec_format == "matrix" %>
    <% exercises = Array(section["exercises"]) %>
    <% n = exercises.size %>
    <% rounds = (1..n).to_a + (n - 1).downto(1).to_a %>
    <% rounds.each_with_index do |count, ri| %>
      <% offset = ri < n ? 0 : ri - n + 1 %>
      <% combo = exercises[offset, count] %>
      <div class="px-3 py-2 border-t border-zinc-700/50">
        <p class="text-white text-sm font-semibold"><%= combo.map { |e|
          metric = if e["duration_s"].to_i > 0
            "#{e["duration_s"].to_i}s "
          elsif e["reps"].to_i > 0
            "#{e["reps"]} "
          end
          "#{metric}#{e["name"]}"
        }.join(" + ") %></p>
      </div>
    <% end %>
  <% else %>
    <% Array(section["exercises"]).each_with_index do |exercise, ei| %>
      <%= render "shared/exercise_row",
            exercise:       exercise,
            section:        section,
            workout:        workout,
            section_index:  section_index,
            exercise_index: ei,
            swappable:      swappable,
            is_tabata:      sec_format == "tabata" %>
    <% end %>
  <% end %>

  <%# Footer: section notes only %>
  <% if section["notes"].present? %>
    <div class="px-3 py-2 border-t border-zinc-600/40 bg-zinc-700/20">
      <p class="text-gray-400 text-xs leading-relaxed"><%= section["notes"] %></p>
    </div>
  <% end %>

</div>
