<div class="bg-zinc-800 border border-volt/30 rounded-2xl overflow-hidden shadow-sm mb-6">

  <%# Header %>
  <div class="bg-gradient-to-r from-volt/15 to-transparent px-5 py-3 border-b border-volt/20 flex items-center justify-between">
    <p class="text-xs font-black text-volt uppercase tracking-widest">Today's Challenge</p>
    <p class="text-xs text-gray-500"><%= challenge.date.strftime("%-d %b %Y") %></p>
  </div>

  <%# Body %>
  <div class="px-5 py-4">
    <h2 class="text-xl font-black text-white uppercase tracking-tight font-jost mb-2"><%= challenge.title %></h2>
    <p class="text-gray-300 text-sm leading-relaxed whitespace-pre-wrap mb-4"><%= challenge.description %></p>

    <% entry = challenge.user_entry(Current.user) %>

    <% if entry %>
      <div class="flex items-center gap-3 bg-volt/10 border border-volt/30 rounded-xl px-4 py-3 mb-4">
        <span class="text-volt font-black text-xs uppercase tracking-wide">Your result</span>
        <span class="text-white font-bold text-sm"><%= format_challenge_score(entry.score, challenge.scoring_type) %></span>
        <% unless entry.rx %>
          <span class="text-gray-500 text-xs border border-zinc-600 px-2 py-0.5 rounded-full">Scaled</span>
        <% end %>
      </div>
    <% else %>
      <details class="group mb-4">
        <summary class="list-none cursor-pointer select-none">
          <div class="flex items-center justify-center gap-2 bg-volt hover:bg-volt/80 active:opacity-90 text-zinc-950 font-black py-3 rounded-xl text-sm transition-colors uppercase tracking-wide cursor-pointer">
            Log Your Result
          </div>
        </summary>
        <div class="mt-3 bg-zinc-900 rounded-xl p-4">
          <%= form_with url: challenge_entries_path, method: :post do |f| %>
            <%= f.hidden_field :daily_challenge_id, value: challenge.id %>
            <div class="mb-3">
              <label class="block text-xs font-bold text-gray-400 uppercase tracking-wide mb-1.5">
                Score
                <span class="text-gray-600 normal-case font-normal ml-1">
                  <%= challenge.scoring_type == "time" ? "(MM:SS)" : challenge.scoring_type == "weight" ? "(kg)" : "(count)" %>
                </span>
              </label>
              <input type="<%= challenge.scoring_type == "time" ? "text" : "number" %>"
                     name="score"
                     placeholder="<%= challenge.scoring_type == "time" ? "e.g. 8:42" : challenge.scoring_type == "weight" ? "e.g. 100" : "e.g. 45" %>"
                     step="<%= challenge.scoring_type == "weight" ? "0.5" : "1" %>"
                     required
                     class="w-full bg-zinc-800 border border-zinc-600 rounded-xl px-4 py-2.5 text-white text-sm focus:outline-none focus:border-lime-400">
            </div>
            <div class="flex items-center gap-3 mb-3">
              <label class="flex items-center gap-2 cursor-pointer">
                <input type="checkbox" name="rx" value="1" checked class="accent-lime-400 w-4 h-4">
                <span class="text-sm text-gray-300 font-medium">Rx (as prescribed)</span>
              </label>
            </div>
            <div class="mb-4">
              <input type="text" name="notes" placeholder="Notes (optional)"
                     class="w-full bg-zinc-800 border border-zinc-600 rounded-xl px-4 py-2 text-white text-sm placeholder-gray-600 focus:outline-none focus:border-lime-400">
            </div>
            <%= f.submit "Submit Result",
                  class: "w-full bg-zinc-700 hover:bg-zinc-600 text-white font-black py-2.5 rounded-xl text-sm transition-colors cursor-pointer uppercase tracking-wide" %>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>

  <%# Live leaderboard %>
  <%= turbo_stream_from "challenge_#{challenge.id}_leaderboard" %>
  <%= turbo_frame_tag "challenge_leaderboard_#{challenge.id}" do %>
    <%= render "challenges/leaderboard", challenge: challenge %>
  <% end %>

</div>
