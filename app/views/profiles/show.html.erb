<% content_for :title, "Profile" %>

<div class="max-w-lg mx-auto pb-16">

  <%# Header %>
  <div class="flex items-center justify-between mb-8">
    <div class="flex items-center gap-4">
      <%= render "shared/avatar", user: @user, classes: "w-14 h-14 text-xl" %>
      <div>
        <h1 class="text-2xl font-bold tracking-tight"><%= @user.display %></h1>
        <% if @user.username.present? %>
          <p class="text-gray-500 text-sm">@<%= @user.username %></p>
        <% end %>
      </div>
    </div>
    <%= link_to edit_profile_path, class: "flex items-center gap-1.5 border border-zinc-600 hover:border-gray-400 text-gray-300 hover:text-white text-sm font-medium px-4 py-2 rounded-xl transition-colors" do %>
      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
        <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
      </svg>
      Edit
    <% end %>
  </div>

  <%# Physical %>
  <% if @user.age.present? || @user.height_cm.present? || @user.weight_kg.present? || @user.gender.present? %>
    <div class="mb-8">
      <h2 class="text-xs font-black uppercase tracking-widest text-gray-500 mb-4">Physical</h2>
      <div class="grid grid-cols-4 gap-3">
        <% if @user.gender.present? %>
          <div class="bg-zinc-800 rounded-xl p-4 text-center">
            <p class="text-lg font-bold text-white"><%= { "male" => "Male", "female" => "Female", "non_binary" => "Non-binary", "prefer_not_to_say" => "—" }[@user.gender] %></p>
            <p class="text-gray-500 text-xs mt-1 uppercase tracking-wide">Gender</p>
          </div>
        <% end %>
        <% if @user.age.present? %>
          <div class="bg-zinc-800 rounded-xl p-4 text-center">
            <p class="text-2xl font-bold text-white"><%= @user.age %></p>
            <p class="text-gray-500 text-xs mt-1 uppercase tracking-wide">Age</p>
          </div>
        <% end %>
        <% if @user.height_cm.present? %>
          <div class="bg-zinc-800 rounded-xl p-4 text-center">
            <p class="text-2xl font-bold text-white"><%= @user.height_cm %><span class="text-sm text-gray-500 font-normal">cm</span></p>
            <p class="text-gray-500 text-xs mt-1 uppercase tracking-wide">Height</p>
          </div>
        <% end %>
        <% if @user.weight_kg.present? %>
          <div class="bg-zinc-800 rounded-xl p-4 text-center">
            <p class="text-2xl font-bold text-white"><%= @user.weight_kg.to_f.round(1) %><span class="text-sm text-gray-500 font-normal">kg</span></p>
            <p class="text-gray-500 text-xs mt-1 uppercase tracking-wide">Weight</p>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Training Environment %>
  <% if @user.run_preference.present? || @user.pool_length.present? || @user.equipment.any? %>
    <div class="mb-8">
      <h2 class="text-xs font-black uppercase tracking-widest text-gray-500 mb-4">Training</h2>
      <div class="space-y-3">
        <% if @user.run_preference.present? %>
          <div class="flex items-center justify-between py-2 border-b border-zinc-800">
            <span class="text-gray-400 text-sm">Run preference</span>
            <span class="text-white text-sm font-medium"><%= @user.run_preference.capitalize %></span>
          </div>
        <% end %>
        <% if @user.pool_length.present? %>
          <div class="flex items-center justify-between py-2 border-b border-zinc-800">
            <span class="text-gray-400 text-sm">Pool</span>
            <span class="text-white text-sm font-medium"><%= @user.pool_length %></span>
          </div>
        <% end %>
        <% if @user.equipment.any? %>
          <div class="py-2">
            <p class="text-gray-400 text-sm mb-2">Equipment</p>
            <div class="flex flex-wrap gap-1.5">
              <% @user.equipment.each do |item| %>
                <span class="bg-zinc-700 text-gray-300 text-xs px-2.5 py-1 rounded-lg"><%= item.humanize %></span>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Personal Bests %>
  <% pb = @user.personal_bests || {} %>
  <% unless pb.empty? %>
    <% def fmt_time_show(secs); return "" if secs.blank? || secs.to_i == 0; s = secs.to_i; h = s/3600; m = (s%3600)/60; r = s%60; h > 0 ? "#{'%02d'%h}:#{'%02d'%m}:#{'%02d'%r}" : "#{'%d'%m}:#{'%02d'%r}"; end %>
    <div class="mb-8">
      <h2 class="text-xs font-black uppercase tracking-widest text-gray-500 mb-4">Personal Bests</h2>
      <div class="space-y-1">
        <% {
          "run_1mile" => "1 Mile Run", "run_1_5mile" => "1.5 Mile Run (Cooper)", "run_5km" => "5km Run", "run_10km" => "10km Run",
          "run_half_marathon" => "Half Marathon",
          "swim_100m_fc" => "100m Freestyle", "swim_400m" => "400m Swim",
          "swim_1500m" => "1500m Swim", "swim_1mile" => "1 Mile Swim",
          "row_500m" => "500m Row", "row_1000m" => "1000m Row", "row_2000m" => "2000m Row",
          "ski_500m" => "500m SkiErg", "ski_2000m" => "2000m SkiErg",
          "assault_bike_50cal" => "Assault Bike 50cal", "assault_bike_100cal" => "Assault Bike 100cal",
          "floor_to_ceiling_30" => "30 Floor-to-Ceilings", "thrusters_50" => "50 Thrusters",
          "wall_balls_100" => "100 Wall Balls", "hyrox_race" => "Hyrox Race", "deka_fit" => "Deka Fit"
        }.each do |key, label| %>
          <% next unless pb[key].present? %>
          <div class="flex items-center justify-between py-2 border-b border-zinc-800">
            <span class="text-gray-400 text-sm"><%= label %></span>
            <span class="text-white text-sm font-mono font-medium"><%= fmt_time_show(pb[key]) %></span>
          </div>
        <% end %>
        <% {
          "bench_1rm" => "Bench Press 1RM", "squat_1rm" => "Back Squat 1RM",
          "deadlift_1rm" => "Deadlift 1RM", "clean_jerk_1rm" => "Clean & Jerk 1RM", "snatch_1rm" => "Snatch 1RM"
        }.each do |key, label| %>
          <% next unless pb[key].present? %>
          <div class="flex items-center justify-between py-2 border-b border-zinc-800">
            <span class="text-gray-400 text-sm"><%= label %></span>
            <span class="text-white text-sm font-medium"><%= pb[key].to_f.round(1) %>kg</span>
          </div>
        <% end %>
        <% {
          "press_ups_2min" => "Press-ups (2 min)", "pull_ups_max" => "Max Pull-ups", "burpees_1min" => "Burpees (1 min)"
        }.each do |key, label| %>
          <% next unless pb[key].present? %>
          <div class="flex items-center justify-between py-2 border-b border-zinc-800">
            <span class="text-gray-400 text-sm"><%= label %></span>
            <span class="text-white text-sm font-medium"><%= pb[key].to_i %> reps</span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Empty state %>
  <% if @user.age.blank? && @user.height_cm.blank? && @user.weight_kg.blank? && @user.gender.blank? && @user.run_preference.blank? && !@user.equipment.any? && pb.empty? %>
    <div class="text-center py-12 text-gray-600">
      <p class="mb-4">No profile info yet.</p>
      <%= link_to edit_profile_path, class: "text-lime-400 hover:text-lime-300 text-sm font-medium" do %>
        Add your details →
      <% end %>
    </div>
  <% end %>

</div>
