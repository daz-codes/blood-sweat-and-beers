<%= form_with model: comment,
               url: workout_log_comments_path(workout_log),
               id: "comment_form_#{workout_log.id}",
               class: "flex items-center gap-2 pt-2.5 border-t border-zinc-700/40" do |f| %>
  <%= f.text_field :body,
        placeholder: "Add a comment…",
        autocomplete: "off",
        class: "flex-1 bg-transparent text-sm text-white placeholder-gray-600 focus:outline-none min-w-0" %>
  <%= f.submit "Post",
        class: "flex-shrink-0 text-xs font-semibold text-lime-400 hover:text-lime-400 transition-colors cursor-pointer disabled:opacity-40" %>
<% end %>
