<%# locals: (workout:, liked:, like_count:) %>
<%= turbo_frame_tag "like_workout_#{workout.id}" do %>
  <%= button_to like_workout_path(workout), method: :post,
      class: "flex items-center gap-1.5 px-3 py-1.5 rounded-full text-sm font-semibold transition-colors #{liked ? 'bg-yellow-400/15 text-lime-400 hover:bg-lime-400/20' : 'bg-zinc-700 text-gray-500 hover:text-gray-300'}" do %>
    🔥 <span><%= like_count %></span>
  <% end %>
<% end %>
