<div class="px-6 py-6">

  <% user_at_limit = Current.user.generation_limit_reached? %>
  <% generations_used = Current.user.free? ? Current.user.generations_this_week : nil %>

  <div class="flex items-start justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold tracking-tight">Generate Workout</h1>
      <% if Current.user.pro? %>
        <p class="text-gray-400 mt-0.5 text-sm">Pick your session type and focus, and we'll build it.</p>
      <% elsif user_at_limit %>
        <p class="text-red-400 mt-0.5 text-sm font-medium">You've used all <%= User::FREE_GENERATION_LIMIT %> free generations this week.</p>
      <% else %>
        <p class="text-gray-400 mt-0.5 text-sm">Pick your session type and focus, and we'll build it.</p>
      <% end %>
    </div>
    <button type="button"
            data-action="click->dialog#close"
            class="flex-shrink-0 ml-2 flex items-center justify-center w-8 h-8 rounded-full text-gray-500 hover:text-white hover:bg-zinc-700 transition-colors focus:outline-none"
            aria-label="Close">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <%= form_with url: workouts_path, data: { controller: "generate-form", action: "submit->generate-form#showSpinner" } do |f| %>

    <%# Session Type — radio pills: defaults + user's recent activities %>
    <div class="mb-6">
      <p class="text-sm font-semibold text-gray-300 uppercase tracking-wide mb-1">Session Type</p>
      <p class="text-xs text-gray-500 mb-3">Pick a session type or type your own below.</p>
      <% user_recent_ids = Current.user.workouts.where.not(activity_id: nil)
                                       .order(created_at: :desc)
                                       .select(:activity_id).distinct.limit(10).map(&:activity_id) %>
      <% activities = Activity.where(id: (Activity.defaults.ids + user_recent_ids).uniq) %>
      <div class="flex flex-wrap gap-2">
        <% activities.each do |activity| %>
          <label class="cursor-pointer">
            <%= radio_button_tag "activity", activity.name, false, id: "activity_#{activity.slug}",
                class: "peer sr-only",
                data: { generate_form_target: "pill", action: "change->generate-form#pillSelected" } %>
            <span class="inline-block border-2 border-zinc-600 rounded-full px-4 py-1.5 text-sm font-medium text-gray-400 peer-checked:border-lime-400 peer-checked:bg-lime-400 peer-checked:text-zinc-900 peer-checked:font-bold transition-all select-none">
              <%= activity.name %>
            </span>
          </label>
        <% end %>
      </div>
      <div class="mt-3 flex items-center gap-3">
        <span class="text-xs text-gray-600 flex-shrink-0">or type your own:</span>
        <%= text_field_tag :custom_activity, nil,
            placeholder: "e.g. Powerlifting, Olympic Lifting, Yoga…",
            class: "flex-1 bg-zinc-800 border border-zinc-700 rounded-xl px-3 py-2 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-lime-400 transition-colors",
            data: { generate_form_target: "customInput", action: "input->generate-form#customTyped" } %>
      </div>
    </div>

    <%# Duration %>
    <div class="mb-6">
      <p class="text-sm font-semibold text-gray-300 uppercase tracking-wide mb-3">Time</p>
      <div data-controller="duration-slider">
        <div class="flex items-baseline justify-between mb-2">
          <span class="text-gray-500 text-xs">Duration</span>
          <p class="text-2xl font-bold text-white">
            <span data-duration-slider-target="display">60</span>
            <span class="text-base font-normal text-gray-400">min</span>
          </p>
        </div>
        <%= f.range_field :duration_mins, value: 60, min: 5, max: 120, step: 5,
            class: "w-full h-2 bg-zinc-700 rounded-lg appearance-none cursor-pointer accent-lime-400",
            data: { duration_slider_target: "input", action: "input->duration-slider#update" },
            required: true %>
        <div class="flex justify-between text-xs text-gray-600 mt-1.5">
          <span>5 min</span>
          <span>2 hrs</span>
        </div>
      </div>
    </div>

    <%# Difficulty %>
    <div class="mb-6">
      <p class="text-sm font-semibold text-gray-300 uppercase tracking-wide mb-3">Difficulty</p>
      <div class="grid grid-cols-3 gap-3">
        <% [["beginner", "Beginner", "Building base fitness"], ["intermediate", "Intermediate", "Regular training"], ["advanced", "Advanced", "Competition prep"]].each do |value, label, desc| %>
          <label class="relative cursor-pointer">
            <%= f.radio_button :difficulty, value, class: "peer sr-only", checked: value == "intermediate" %>
            <div class="border-2 border-zinc-600 rounded-xl p-3 peer-checked:border-lime-400 peer-checked:bg-lime-400/10 transition-all text-center">
              <p class="font-semibold text-sm"><%= label %></p>
              <p class="text-gray-500 text-xs mt-0.5"><%= desc %></p>
            </div>
          </label>
        <% end %>
      </div>
    </div>

    <%# Session Notes — free text, anything goes %>
    <div class="mb-6">
      <p class="text-sm font-semibold text-gray-300 uppercase tracking-wide mb-1">Session Notes</p>
      <p class="text-xs text-gray-500 mb-3">Injuries, equipment, intensity, focus — anything that should shape this session.</p>
      <%= text_field_tag :session_notes, nil,
          placeholder: "e.g. injured knee · hotel gym · zone 2 only · upper body · no running",
          class: "w-full bg-zinc-800 border border-zinc-600 rounded-xl px-4 py-2.5 text-sm text-white placeholder-gray-600 focus:outline-none focus:border-lime-400 transition-colors" %>
    </div>

    <%# Workout Tag — hidden until tagging UX is designed (see project memory) %>

    <% if Rails.env.development? %>
      <%# Experiment: example-based prompt toggle %>
      <div class="flex items-center gap-3 mb-6">
        <%= check_box_tag :prompt_mode, "examples", false, class: "w-4 h-4 accent-lime-400 cursor-pointer" %>
        <label for="prompt_mode" class="text-sm text-gray-400 cursor-pointer">
          Use example-based prompt <span class="text-gray-600">(experimental)</span>
        </label>
      </div>
    <% end %>

    <% unless user_at_limit %>
      <% if Current.user.free? %>
        <p class="text-gray-600 text-xs text-center mb-3">
          <%= generations_used %> of <%= User::FREE_GENERATION_LIMIT %> free generations used this week
          · <%= button_to "Upgrade to Pro", upgrade_subscription_path, method: :patch, form: { data: { turbo: true } },
              class: "text-volt hover:text-volt/80 inline cursor-pointer bg-transparent border-0 p-0 text-xs" %>
        </p>
      <% else %>
        <div class="flex items-center justify-center gap-1.5 mb-3">
          <span class="bg-volt text-zinc-950 text-[10px] font-black uppercase tracking-wider px-2 py-0.5 rounded-full">Pro</span>
          <span class="text-gray-500 text-xs">Unlimited generations</span>
        </div>
      <% end %>
      <%= f.submit "Generate Workout",
          class: "w-full bg-volt hover:bg-volt/80 active:opacity-90 text-zinc-950 font-bold py-3.5 rounded-xl text-lg transition-colors cursor-pointer",
          data: { generate_form_target: "submitBtn" } %>
    <% end %>

  <% end %>

  <% if user_at_limit %>
    <div class="bg-zinc-800 border border-zinc-600 rounded-xl p-4 mb-4 text-center">
      <p class="text-white font-bold text-sm mb-1">Weekly limit reached</p>
      <p class="text-gray-400 text-xs mb-3">Upgrade to Pro for unlimited AI-generated workouts, Sonnet 4.6 model, and more.</p>
      <%= button_to "Upgrade to Pro",
          upgrade_subscription_path,
          method: :patch,
          class: "inline-block w-full bg-volt hover:bg-volt/80 text-zinc-950 font-bold py-3 rounded-xl text-base transition-colors text-center cursor-pointer" %>
    </div>
  <% end %>

</div>
