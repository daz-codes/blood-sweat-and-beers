<% content_for :title, @workout.name.presence || "Workout" %>

<% own_workout = Current.user == @workout.user %>

<div class="max-w-2xl mx-auto">

  <%# Mobile-only: actions first, then like %>
  <div class="sm:hidden mb-4 space-y-3">
    <div class="flex gap-2">
      <button type="button"
              onclick="document.getElementById('complete_workout_<%= @workout.id %>').showModal()"
              class="flex-1 text-center bg-volt hover:bg-volt/80 active:opacity-90 text-zinc-950 font-black py-3 rounded-xl text-sm transition-colors uppercase tracking-wide cursor-pointer">
        Do this
      </button>
      <% unless own_workout %>
        <%= button_to "Save", save_workout_path(@workout), method: :post,
            data: { turbo_frame: "_top" },
            form: { class: "contents" },
            class: "flex-1 text-center py-3 px-4 border border-zinc-600 hover:border-gray-500 text-gray-300 hover:text-white font-bold rounded-xl text-sm transition-colors cursor-pointer" %>
      <% end %>
      <% if own_workout %>
        <%= link_to "Edit", edit_workout_path(@workout),
            data: { turbo_frame: "workout_preview" },
            class: "flex-1 text-center py-3 px-4 border border-zinc-600 hover:border-lime-400 hover:text-lime-400 text-gray-300 font-bold rounded-xl text-sm transition-colors" %>
      <% end %>
    </div>
    <div class="flex items-center justify-between">
      <%= link_to root_path, class: "text-gray-500 hover:text-gray-300 text-sm" do %>&larr; Feed<% end %>
    </div>
  </div>

  <%# Desktop: back %>
  <div class="hidden sm:flex mb-6 items-center justify-between">
    <%= link_to root_path, class: "text-gray-500 hover:text-gray-300 text-sm" do %>&larr; Feed<% end %>
  </div>

  <%= turbo_frame_tag "workout_preview" do %>
    <%= render "workouts/preview", workout: @workout, debug_info: @debug_info %>
  <% end %>

</div>
